# Speech to Text Transcription App - environment template
#
# IMPORTANT:
# - The browser app currently reads API credentials from the Settings UI
#   and stores them in localStorage.
# - These values are NOT loaded automatically by runtime client code.
# - Do not put real secrets in client-side bundles or committed files.

# Optional: Node/test environment mode (used by tooling/tests only)
NODE_ENV=development

# Optional: mock values for local scripts/integration testing
# Keep these fake to avoid secret-scanner noise.
TEST_MOCK_API_KEY=mock-api-key-for-testing
TEST_MOCK_ENDPOINT=https://mock.test.azure.com/

# Deprecated examples kept here for migration context only.
# The app does not currently consume these env vars directly.
# AZURE_SPEECH_API_KEY=
# AZURE_SPEECH_ENDPOINT=
# OPENAI_API_KEY=
# OPENAI_ENDPOINT=