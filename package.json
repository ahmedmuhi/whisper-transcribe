{
  "name": "whisper-transcribe",
  "version": "1.0.0",
  "private": true,
  "description": "A lightweight web application that converts spoken audio to text using Azure's Speech Services. Record directly from your browser and get transcriptions in real-time.",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "lint": "eslint \"js/**/*.js\"",
    "lint:fix": "eslint --fix \"js/**/*.js\"",
    "deps:check": "knip",
    "deps:check:prod": "knip --production --dependencies",
    "size": "size-limit"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@size-limit/file": "^11.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.30.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "happy-dom": "^18.0.1",
    "husky": "^9.1.7",
    "knip": "^5.61.3",
    "size-limit": "^11.2.0",
    "vitest": "^3.2.4"
  },
  "size-limit": [
    {
      "path": "js/*.js",
      "limit": "100 kB"
    }
  ]
}
