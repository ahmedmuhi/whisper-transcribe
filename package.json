{
  "name": "whisper-transcribe",
  "version": "2.0.0",
  "private": true,
  "license": "MIT",
  "description": "A Vite-built, browser-only Bring-your-own Azure transcription app with Microsoft Entra sign-in.",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4176 --strictPort",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:browser": "playwright test",
    "test:browser:headed": "playwright test --headed",
    "test:browser:live": "npm run build && playwright test --config playwright.live.config.js",
    "prepare": "husky",
    "lint": "eslint \"js/**/*.js\" \"tests/**/*.{js,mjs}\" \"*.config.js\"",
    "lint:fix": "eslint --fix \"js/**/*.js\" \"tests/**/*.{js,mjs}\" \"*.config.js\"",
    "deps:check": "knip",
    "deps:check:prod": "knip --production --dependencies",
    "size": "size-limit"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.61.1",
    "@size-limit/file": "^11.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.30.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.2",
    "husky": "^9.1.7",
    "knip": "^5.61.3",
    "size-limit": "^11.2.0",
    "vite": "8.1.5",
    "vitest": "^3.2.4"
  },
  "size-limit": [
    {
      "name": "application",
      "path": [
        "dist/assets/main-*.js",
        "dist/assets/constants-*.js",
        "dist/assets/visualization-*.js",
        "dist/assets/modulepreload-polyfill-*.js",
        "dist/assets/audio-converter.worker-*.js"
      ],
      "limit": "20 kB"
    },
    {
      "name": "authentication runtime",
      "path": "dist/assets/authentication-*.js",
      "limit": "55 kB"
    },
    {
      "name": "redirect bridge",
      "path": "dist/assets/redirect-*.js",
      "limit": "5 kB"
    }
  ],
  "dependencies": {
    "@azure/msal-browser": "5.17.1"
  }
}
