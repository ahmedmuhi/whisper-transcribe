{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["js/main.js"],
  "project": ["js/**/*.js"],
  "ignore": [
    "coverage/**",
    "docs/**",
    "plan/**",
    "*.config.js",
    ".husky/**"
  ],
  "ignoreExportsUsedInFile": true,
  "includeEntryExports": true,
  "eslint": {
    "entry": ["eslint.config.js"],
    "project": ["eslint.config.js"]
  },
  "husky": {
    "entry": [".husky/**/*"]
  },
  "vitest": {
    "entry": ["tests/**/*.vitest.js"],
    "project": ["tests/**/*.vitest.js"]
  }
}
